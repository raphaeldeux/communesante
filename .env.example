# Base de données PostgreSQL
POSTGRES_PASSWORD=mot_de_passe_fort_a_changer

# Token d'authentification API (générer avec: openssl rand -hex 32)
API_SECRET_TOKEN=token_32_chars_aleatoires_a_changer

# Code INSEE de la commune par défaut (Sautron)
COMMUNE_INSEE=44196

# Clé API DGFiP (optionnel si utilisation data.gouv.fr)
DGFIP_API_KEY=

# Domaine pour Nginx / TLS (laisser vide pour localhost)
DOMAIN=

# Fréquence de synchronisation DGFiP (cron expression)
# 0 3 * * 0 = chaque dimanche à 3h du matin
SYNC_CRON=0 3 * * 0

# Niveau de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
